    LTEXT           "]",IDC_LABEL_YFX_RBRACE,304,91,8,8
    GROUPBOX        "Parametric",IDC_PARAM_GROUP,10,105,300,48
    LTEXT           "x(t) =",IDC_LABEL_PAR_XT,20,119,28,8
    EDITTEXT        IDC_CURVE_PARAM_X_EDIT,55,117,120,12,ES_AUTOHSCROLL
    LTEXT           "y(t) =",IDC_LABEL_PAR_YT,20,135,28,8
    EDITTEXT        IDC_CURVE_PARAM_Y_EDIT,55,133,120,12,ES_AUTOHSCROLL
    LTEXT           "t in [",IDC_LABEL_PAR_TRANGE,185,119,28,8
    EDITTEXT        IDC_CURVE_TRANGE_FROM,200,117,96,12,ES_AUTOHSCROLL
    LTEXT           ",",IDC_LABEL_PAR_COMMA,301,119,8,8
    EDITTEXT        IDC_CURVE_TRANGE_TO,200,135,96,12,ES_AUTOHSCROLL
    LTEXT           "]",IDC_LABEL_PAR_RBRACE,299,138,8,8
    GROUPBOX        "Polar r = f(t)",IDC_POLAR_GROUP,10,160,300,38
    LTEXT           "r =",IDC_LABEL_POLAR_R,20,174,16,8
    EDITTEXT        IDC_CURVE_EXPR_POLAR_EDIT,40,172,120,12,ES_AUTOHSCROLL
    LTEXT           "t in [",IDC_LABEL_POLAR_PHIRANGE,170,174,28,8
    EDITTEXT        IDC_POLAR_PHI_FROM,188,171,114,12,ES_AUTOHSCROLL
    LTEXT           ",",IDC_LABEL_POLAR_COMMA,301,174,8,8
    EDITTEXT        IDC_POLAR_PHI_TO,188,185,114,12,ES_AUTOHSCROLL
    LTEXT           "]",IDC_LABEL_POLAR_RBRACE,303,187,8,8
    GROUPBOX        "Implicit f(x, y) = 0",IDC_IMPLICIT_GROUP,10,205,300,48
