IDD_ADDCURVEDIALOG DIALOGEX 0, 0, 371, 320
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Add Curve"
FONT 9, "Segoe UI", 0, 0, 0x1
BEGIN
    GROUPBOX        "Curve Type",IDC_STATIC,10,10,300,32
    CONTROL         "y = f(x)",IDC_CURVETYPE_YFX,"Button",BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP,20,25,37,10
    CONTROL         "Parametric  x(t), y(t)",IDC_CURVETYPE_PARAM,"Button",BS_AUTORADIOBUTTON,71,25,73,10
    CONTROL         "Polar r = f(t)",IDC_CURVETYPE_POLAR,"Button",BS_AUTORADIOBUTTON,166,25,52,10
    CONTROL         "Implicit function",IDC_CURVETYPE_IMPLICIT,"Button",BS_AUTORADIOBUTTON,243,25,65,10
    LTEXT           "Label:",IDC_STATIC,10,48,30,8
    EDITTEXT        IDC_CURVE_LABEL_EDIT,50,46,250,12,ES_AUTOHSCROLL
    GROUPBOX        "y = f(x)",IDC_YFX_GROUP,10,62,300,38
    LTEXT           "y =",IDC_LABEL_YFX_Y,20,76,16,8
    EDITTEXT        IDC_CURVE_EXPR_YFX_EDIT,40,74,180,12,ES_AUTOHSCROLL
    LTEXT           "x in [",IDC_LABEL_YFX_XRANGE,230,76,24,8
